# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# Flask
SECRET_KEY=your-secret-key-here

# Google OAuth (required)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: override the default redirect URI
# GOOGLE_REDIRECT_URI=https://your-app.onrender.com/auth/callback

# Database (leave blank to use local SQLite)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# DATABASE_PATH=/tmp/nemsu_laf.db

# Gmail notifications (leave blank to disable)
GMAIL_SENDER_EMAIL=
GMAIL_REFRESH_TOKEN=

# App base URL (for email links)
APP_BASE_URL=

# ImgBB image hosting
IMGBB_API_KEY=

# Gemini AI chatbot
GEMINI_API_KEY=

# Set to any non-empty value on production
# PRODUCTION=1
